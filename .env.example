# Turso / libSQL
# - On Vercel you should set DATABASE_URL (and usually DATABASE_AUTH_TOKEN) to make data persistent.
# - Locally you can either set these too (recommended) or omit them to use a local SQLite file DB.
# Example: libsql://your-db-name-your-org.turso.io
DATABASE_URL=
DATABASE_AUTH_TOKEN=

# Authentication secret for session signing (generate a random secret for production)
AUTH_SECRET=

# Optional admin login override (takes priority over database-stored credentials)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

# Timezone used for attendance/date logic
APP_TIMEZONE=Asia/Riyadh

# Google OAuth credentials (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ALLOWED_EMAIL_DOMAIN=stu.kfs.sch.sa

# Used to build OAuth redirect URLs in production (optional if VERCEL_URL exists)
NEXTAUTH_URL=
